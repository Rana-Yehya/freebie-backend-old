model StoreSubscription {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Current active plan
  planLimit   PlanLimit?         @relation(fields: [planLimitId], references: [id], onDelete: SetNull)
  planLimitId String?
  status      SubscriptionStatus @default(ACTIVE)

  // Billing period (Nov 1 - Nov 30)
  currentPeriodStart DateTime // 2024-11-01
  currentPeriodEnd   DateTime // 2024-11-30

  // Plan limits are now PER STORE (aggregate of all branches)
  maxTotalProducts     Int @default(50) // Total across all branches
  maxBranches          Int @default(1) // How many branches allowed
  maxDiscountCodes     Int @default(0) // Total discount codes across all branches
  notificationsPerWeek Int @default(0)
  adsPerWeek           Int @default(0)

  // Features
  allowsBoxes          Boolean @default(false)
  allowsCollaborations Boolean @default(false)

  // Pricing
  commissionRate Float  @default(0.14)
  monthlyPrice   Float?
  annualPrice    Float?

  // Simple ad counter - reset each period
  adsUsedThisPeriod Int       @default(0) // Tracks 0, 1, 2...
  adsResetAt        DateTime? // Set to currentPeriodEnd

  // For pending downgrades
  downgradeToPlan      PlanName?
  downgradeScheduledAt DateTime?

  // Relations
  // store       store?
  planChanges SubscriptionPlanChange[]

  @@map("store_subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_DOWNGRADE
  CANCELLED
  EXPIRED
}
