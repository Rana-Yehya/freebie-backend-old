model storeSubscription {
  id          String             @id @default(uuid())
  // Current active plan
  planLimit   planLimit          @relation(fields: [planLimitId], references: [planName])
  planLimitId PlanName
  status      SubscriptionStatus @default(ACTIVE)

  lastChangeSubscriptionDate DateTime?
  periodEnd                  DateTime?
  // Plan limits are now PER STORE (aggregate of all branches)
  maxTotalProducts           Int       @default(0) // Total across all branches
  maxBranches                Int       @default(0) // How many branches allowed
  maxDiscountCodes           Int       @default(0) // Total discount codes across all branches
  notificationsPerWeek       Int       @default(0)
  adsPerWeek                 Int       @default(0)
  
  // Features
  // allowsBoxes          Boolean @default(false)
  // allowsCollaborations Boolean @default(false)

  // Pricing
  commissionRate Float @default(0.14)

  // Simple ad counter - reset each period
  // adsUsedThisPeriod Int       @default(0) // Tracks 0, 1, 2...
  // adsResetAt        DateTime? // Set to currentPeriodEnd

  // Relations
  // store       store?
  planChanges subscriptionPlanChange[]
  store       store[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@map("store_subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_DOWNGRADE
  CANCELLED
  EXPIRED
}
