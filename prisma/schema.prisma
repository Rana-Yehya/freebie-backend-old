// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model image {
  id          String     @id @unique @default(uuid())
  publicId    String
  secureUrl   String
  // userId String? 
  // users  user?   
  category    category[]
  occasion    occasion[]
  product     product?   @relation(fields: [productId], references: [id])
  productId   String?
  storeLogo   store[]    @relation("storeLogo")
  storeBanner store[]    @relation("storeBanner")
}

model user {
  id                 String        @id @unique @default(uuid())
  name               String
  dateOfBirth        DateTime?
  gender             String?
  moneyInPocket      Float         @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  countryId          String?
  userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  stateId            String?
  userState          state?        @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  phone              String        @unique
  email              String?       @unique @default("")
  password           String?
  role               String        @default("user")
  isVerified         Boolean       @default(false)
  refreshTokenSecret String?
  accessTokenSecret  String?
  fcmToken           String?
  transaction        transaction[]
  userCart           userCart[]
  review             review[]
  order              order[]

  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}

model branch {
  id           String         @id @unique @default(uuid())
  storeId      String
  store        store          @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  address      String
  state        state          @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId      String
  phone        String?
  isFreezed    Boolean        @default(false)
  workHours    workHour[]
  productStock productStock[]
  productUser  productCart[]
  productOrder productOrder[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // branchCity        String
  // branchState       String
  // branchZip         String
  // branchLat         Float
  // branchLng         Float
  // country   country?    @relation(fields: [countryId], references: [id])
  // countryId String?
}

model workHour {
  id        String   @id @unique @default(uuid())
  branchId  String   @unique
  branch    branch   @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  startTime DateTime
  endTime   DateTime
  day       Int
}

model store {
  id                 String        @id @unique @default(uuid())
  name               String
  bio                String
  logoId             String        @unique
  logo               image         @relation("storeLogo", fields: [logoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bannerId           String        @unique
  banner             image         @relation("storeBanner", fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone              String        @unique
  email              String        @unique
  password           String
  socialLinksId      String        @unique
  socialLinks        socialLink    @relation(fields: [socialLinksId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branches           branch[]
  paymentId          String?
  transactions       transaction[]
  refreshTokenSecret String?
  accessTokenSecret  String?
  moneyInPocket      Float         @default(0)
  fcmToken           String?

  // product            product[]
  // store - restaurant - place for weddings
  role              String   @default("store")
  isApprovedByAdmin Boolean  @default(false)
  isFreezed         Boolean  @default(false)
  isBanned          Boolean  @default(false)
  isDeleted         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  // storeAddress storeAddress[]
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  // twitter    String
  store     store[]
}

model country {
  id             String   @id @unique @default(uuid())
  countryName    String
  currencyCode   String
  countryIsoCode String   @unique
  user           user[]
  state          state[]
  order          order[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model state {
  id                       String          @id @unique @default(uuid())
  name                     String
  country                  country         @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId                String
  city                     city[]
  branches                 branch[]
  originDeliveryTaxes      deliveryTaxes[] @relation("OriginStateFees")
  destinationDeliveryTaxes deliveryTaxes[] @relation("DestinationStateFees")
  user                     user[]
  order                    order[]
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

model city {
  id        String   @id @unique @default(uuid())
  name      String
  state     state    @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // order     order[]
}

model deliveryTaxes {
  id                    String        @id @unique @default(uuid())
  // name               String
  originState           state         @relation("OriginStateFees", fields: [originStateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  originStateId         String
  destinationState      state         @relation("DestinationStateFees", fields: [destinationStateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  destinationStateId    String
  productUser           productCart[]
  baseFee               Float
  additionalFeesAfterKg Float         @default(100)
  feePerKg              Float         @default(0)
  estimatedDays         Int?
  effectiveDate         DateTime      @default(now())
  expiryDate            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("delivery_taxes")
}

model category {
  id                         String    @id @unique @default(uuid())
  name                       String
  imageId                    String
  image                      image     @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product                    product[]
  canBeDeliveredOutsideState Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

model occasion {
  id        String    @id @unique @default(uuid())
  name      String
  imageId   String
  image     image     @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productOccasion productOccasion[]
  // userId          String
  // user            user              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products  product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model product {
  id                         String         @id @unique @default(uuid())
  name                       String
  // image                      String[]
  image                      image[]
  description                String
  detailedDescription        String
  // store                    store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // storeId                  String
  // user                     user?             @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  // userId                   String?
  price                      Float          @default(1)
  actualPrice                Float          @default(1)
  doesNeedPreparation        Boolean        @default(false)
  isAcceptedByAdmin          Boolean        @default(false)
  isAvailable                Boolean        @default(true)
  isFeatured                 Boolean        @default(false)
  isPopular                  Boolean        @default(false)
  preparationTimeInMinutes   Int            @default(1)
  discountPercent            Float?         @default(0)
  discountStartTime          DateTime?
  discountEndTime            DateTime?
  canBeDeliveredOutsideState Boolean        @default(true)
  productStock               productStock[]
  category                   category       @relation(fields: [categoryId], references: [id], onDelete: SetDefault, onUpdate: SetDefault)
  categoryId                 String         @default("no_val")
  // branch                   branches  @relation(fields: [branchId], references: [id], onDelete: SetDefault, onUpdate: SerDefault)
  // branchId                 String    @default("no_val")
  occasions                  occasion[]
  avgRating                  Float          @default(0)
  reviewsCount               Int            @default(0)
  reviews                    review[]
  dimensionsWCm              Float          @default(1)
  dimensionsHCm              Float          @default(1)
  dimensionsLCm              Float          @default(1)
  weightInKg                 Float          @default(3)
  productOrder               productOrder[]
  productUser                productCart[]
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
}

model productStock {
  // id                       String    @id @unique @default(uuid())
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String
  branch    branch   @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branchId  String
  stock     Int?
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId, color])
}

model review {
  // id                       String    @id @unique @default(uuid())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String   @unique
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String   @unique
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model userCart {
  id          String        @id @default(uuid())
  userId      String        @unique
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product     productCart[]
  subtotal    Float         @default(0)
  taxAmount   Float         @default(0)
  deliveryFee Float         @default(0)
  totalAmount Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // @@id([userId, productId])
  // product   product? @relation(fields: [productId], references: [id])
  // productId String?
}

model productCart {
  // id         String   @id @unique @default(uuid())
  cart                   userCart      @relation(fields: [userCartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userCartId             String
  product                product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId              String
  branch                 branch        @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branchId               String
  deliveryTaxes          deliveryTaxes @relation(fields: [deliveryTaxesId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deliveryTaxesId        String
  color                  String
  quantity               Int           @default(1)
  doesHaveEnoughQuantity Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([userCartId, productId, color, branchId])
}

model order {
  id                    String         @id @unique @default(uuid())
  userId                String
  user                  user           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  trackingNumber        String
  productOrder          productOrder[]
  subtotal              Float          @default(0)
  taxAmount             Float          @default(0)
  deliveryFee           Float          @default(0)
  totalAmount           Float          @default(0)
  paymentMethod         String //credit_card, paypal, mobile.
  // cityId                String
  // city                  city           @relation(fields: [cityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId               String
  state                 state          @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId             String
  country               country        @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  address               String
  notes                 String
  status                String         @default("pending") //pending, confirmed, shipped, delivered, cancelled, refunded
  cancellationReason    String?
  refundAmount          Float?
  currency              String         @default("EGP")
  estimatedDeliveryDate DateTime       @default(dbgenerated("(NOW() + '7 days'::interval)"))
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model productOrder {
  // id         String   @id @unique @default(uuid())
  order              order   @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId            String
  product            product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId          String
  branch             branch  @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branchId           String
  color              String
  quantity           Int     @default(1)
  price              Float   @default(0)
  status             String  @default("pending") //pending, confirmed, shipped, delivered, cancelled, refunded
  cancellationReason String?
  refundAmount       Float?
  subtotal           Float   @default(0)

  @@unique([orderId, productId, color, branchId])
}

model transaction {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  //deposit , withdraw
  type      String   @default("deposit")
  user      user?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String?
  store     store?   @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId   String?
  amount    Float
  purpose   String?
  currency  String   @default("EGP")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model info {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  slug      String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model inbox {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  email     String
  name      String
  message   String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
