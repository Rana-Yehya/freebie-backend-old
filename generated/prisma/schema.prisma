generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== branch.prisma =====
model branch {
  id         String    @id @unique @default(uuid())
  storeId    String
  store      store     @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  location   location? @relation(fields: [locationId], references: [id])
  locationId String?   @unique
  // location     location?

  phone        String?
  isFreezed    Boolean        @default(false)
  workHours    workHour[]
  productStock productStock[]
  // productUser  productCart[]
  // productOrder productOrder[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // branchCity        String
  // branchState       String
  // branchZip         String
  // branchLat         Float
  // branchLng         Float
  // country   country?    @relation(fields: [countryId], references: [id])
  // countryId String?
}

// model branchlocation {
//   id       String  @id @unique @default(uuid())
//   address  String
//   state    state   @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
//   stateId  String
//   branchId String @unique
//   branch   branch @relation(fields: [branchId], references: [id])
//  }

model workHour {
  id        String   @id @unique @default(uuid())
  branchId  String   @unique
  branch    branch   @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  startTime DateTime
  endTime   DateTime
  day       Int
}

// ===== category.prisma =====
model category {
  id                         String    @id @unique @default(uuid())
  nameId                     String?   @unique
  name                       locale?   @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  imageId                    String
  image                      image     @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product                    product[]
  canBeDeliveredOutsideState Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

// ===== city.prisma =====
model city {
  id        String   @id @unique @default(uuid())
  nameId    String?  @unique
  name      locale?  @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  state     state    @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // order     order[]
}

// ===== country.prisma =====
model country {
  id             String   @id @unique @default(uuid())
  nameId         String   @unique
  name           locale   @relation(fields: [nameId], references: [id])
  currencyCode   String
  countryIsoCode String   @unique
  user           user[]
  state          state[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ===== currency.prisma =====
model currency {
  id            String        @id @unique @default(uuid())
  nameId        String        @unique
  name          locale        @relation("currencyName", fields: [nameId], references: [id])
  currencyAbbId String        @unique
  currencyAbb   locale        @relation("currencyAbbLocale", fields: [currencyAbbId], references: [id])
  order         order[]
  transaction   transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ===== delivery-taxes.prisma =====
model deliveryTaxes {
  id                    String        @id @unique @default(uuid())
  // name               String
  originState           state         @relation("OriginStateFees", fields: [originStateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  originStateId         String
  destinationState      state         @relation("DestinationStateFees", fields: [destinationStateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  destinationStateId    String
  productCart           productCart[]
  baseFee               Float
  additionalFeesAfterKg Float         @default(100)
  feePerKg              Float         @default(0)
  estimatedDays         Int?
  effectiveDate         DateTime      @default(now())
  expiryDate            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  // government            government?   @relation(fields: [governmentId], references: [id])
  // governmentId          String?

  @@map("delivery_taxes")
}

// ===== image.prisma =====
model image {
  id          String     @id @unique @default(uuid())
  publicId    String
  secureUrl   String
  // userId String? 
  // users  user?   
  category    category[]
  occasion    occasion[]
  product     product?   @relation(fields: [productId], references: [id])
  productId   String?
  storeLogo   store[]    @relation("storeLogo")
  storeBanner store[]    @relation("storeBanner")
}

// ===== inbox.prisma =====
model inbox {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  email     String
  name      String
  message   String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== info.prisma =====
model info {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  slug      String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== locale.prisma =====
model locale {
  id                         String    @id @unique @default(uuid())
  default                    String?
  en                         String?
  // localeFr      String?
  // localeDe      String?
  // localeEs      String?
  // localeIt      String?
  // localePt      String?
  // localeRu      String?
  // localeZh      String?
  // localeJa      String?
  // localeKo      String?
  ar                         String?
  // localePl      String?
  // localeTr      String?
  // localeCn      String?
  // productId   String? @unique
  nameProduct                product?  @relation("nameProduct") //@relation("locale", fields: [localeProductId], references: [id]) // @relation("ProductTolocale", fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  country                    country?
  state                      state?
  storeName                  store?    @relation("storeName")
  storeBio                   store?    @relation("storeBio")
  currencyAbbLocale          currency? @relation("currencyAbbLocale")
  currencyName               currency? @relation("currencyName")
  city                       city?
  category                   category?
  occasion                   occasion?
  descriptionProduct         product?  @relation("descriptionProduct") //, references: [id], fields: [descriptionProductId])
  detailedDescriptionProduct product?  @relation("detailedDescriptionProduct") //, references: [id], fields: [detailedDescriptionProductId])
}

// ===== location.prisma =====
model location {
  id       String  @id @unique @default(uuid())
  address  String
  state    state   @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId  String
  branchId String?
  branch   branch?
  order    order?
}

// ===== occasion.prisma =====
model occasion {
  id        String    @id @unique @default(uuid())
  nameId    String?   @unique
  name      locale?   @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  imageId   String
  image     image     @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productOccasion productOccasion[]
  // userId          String
  // user            user              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products  product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ===== order.prisma =====
model order {
  id                 String         @id @unique @default(uuid())
  userId             String
  user               user           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  trackingNumber     String
  productOrder       productOrder[]
  subtotal           Float          @default(0)
  taxAmount          Float          @default(0)
  deliveryFee        Float          @default(0)
  totalAmount        Float          @default(0)
  paymentMethod      String //credit_card, paypal, mobile.
  location           location       @relation(fields: [locationId], references: [id])
  locationId         String         @unique
  notes              String
  cancellationReason String?
  refundAmount       Float?
  currencyId         String?
  currency           currency?      @relation(fields: [currencyId], references: [id])
  // estimatedDeliveryDate DateTime       @default(dbgenerated("(NOW() + '7 days'::interval)"))
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

// ===== product-cart.prisma =====
model productCart {
  userCart       userCart     @relation(fields: [userCartUserId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  userCartUserId String
  // id         String   @id @unique @default(uuid())
  // cart                   user          @relation(fields: [userCartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // userCartId             String
  // product                product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId              String
  // branch                 branch        @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // branchId               String
  productStock   productStock @relation(fields: [productStockId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productStockId String

  deliveryTaxes          deliveryTaxes @relation(fields: [deliveryTaxesId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deliveryTaxesId        String
  // color                  String
  quantity               Int           @default(1)
  doesHaveEnoughQuantity Boolean       @default(true)
  oldQuantity            Int?          @default(0)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //userCartId
  @@unique([userCartUserId, productStockId])
  @@map("product_cart")
}

// ===== product-order.prisma =====
model productOrder {
  id             String        @id @unique @default(uuid())
  order          order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId        String
  // product            product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId          String
  // branch             branch  @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // branchId           String
  // color              String
  productStock   productStock? @relation(fields: [productStockId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productStockId String?

  quantity           Int     @default(1)
  price              Float   @default(0)
  deliveryFee        Float   @default(0)
  subtotal           Float   @default(0)
  status             String  @default("pending") //pending, confirmed, shipped, delivered, cancelled, refunded
  cancellationReason String?
  refundAmount       Float?

  @@map("product_order")
}

// ===== product-price.prisma =====
model productPrice {
  productId String  @unique
  product   product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  actualPrice Float? // @default(1)

  discountPercent   Float?    @default(0)
  discountStartTime DateTime?
  discountEndTime   DateTime?

  @@map("product_price")
}

// ===== product-stock.prisma =====
model productStock {
  id           String         @id @unique @default(uuid())
  product      product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId    String
  branch       branch         @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branchId     String
  stock        Int?
  color        String
  productOrder productOrder[]
  productCart  productCart[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([productId, branchId, color])
  @@map("product_stock")
}

// ===== product.prisma =====
// Big sales

//  1 100 000  20%       price = 80 000
//  2 2000     5%        price = 1900
enum productTags {
  FEATURED
  POPULAR
  NONE
}

model product {
  id                    String  @id @unique @default(uuid())
  nameId                String  @unique
  name                  locale  @relation("nameProduct", fields: [nameId], references: [id])
  // image                      String[]
  image                 image[]
  // description                String
  descriptionId         String  @unique
  description           locale  @relation("descriptionProduct", fields: [descriptionId], references: [id])
  detailedDescriptionId String  @unique
  detailedDescription   locale  @relation("detailedDescriptionProduct", fields: [detailedDescriptionId], references: [id])

  // detailedDescription        String
  // store                    store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // storeId                  String
  // user                     user?             @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  // userId                   String?
  price                      Float          @default(1)
  productPrice               productPrice?
  doesNeedPreparation        Boolean        @default(false)
  isAcceptedByAdmin          Boolean        @default(false)
  isAvailable                Boolean        @default(true)
  // isFeatured               Boolean   @default(false)
  // isPopular                Boolean   @default(false)
  tags                       productTags?
  preparationTimeInMinutes   Int            @default(1)
  canBeDeliveredOutsideState Boolean        @default(true)
  productStock               productStock[]
  category                   category?      @relation(fields: [categoryId], references: [id], onDelete: SetDefault, onUpdate: SetDefault)
  categoryId                 String?
  // branch                   branches  @relation(fields: [branchId], references: [id], onDelete: SetDefault, onUpdate: SerDefault)
  // branchId                 String    @default("no_val")
  occasions                  occasion[]
  avgRating                  Float          @default(0)
  reviewsCount               Int            @default(0)
  reviews                    review[]
  dimensionsWCm              Float          @default(1)
  dimensionsHCm              Float          @default(1)
  dimensionsLCm              Float          @default(1)
  weightInKg                 Float          @default(3)
  // productOrder               productOrder[]
  // productUser                productCart[]
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
}

// ===== review.prisma =====
model review {
  // id                       String    @id @unique @default(uuid())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String   @unique
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String   @unique
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

// ===== state.prisma =====
model state {
  id                       String          @id @unique @default(uuid())
  // name                     String
  nameId                   String          @unique
  name                     locale          @relation(fields: [nameId], references: [id]) //onDelete: SetNull, onUpdate: SetNull
  country                  country         @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId                String
  city                     city[]
  originDeliveryTaxes      deliveryTaxes[] @relation("OriginStateFees")
  destinationDeliveryTaxes deliveryTaxes[] @relation("DestinationStateFees")
  user                     user[]
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  location                 location[]
}

// ===== store.prisma =====
model store {
  id     String @id @unique @default(uuid())
  nameId String @unique
  name   locale @relation("storeName", fields: [nameId], references: [id])
  bioId  String @unique
  bio    locale @relation("storeBio", fields: [bioId], references: [id])

  // name               String
  // bio                String
  logoId             String        @unique
  logo               image         @relation("storeLogo", fields: [logoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bannerId           String        @unique
  banner             image         @relation("storeBanner", fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone              String        @unique
  email              String        @unique
  password           String
  // socialLinksId      String    
  socialLinks        socialLink? //  @relation(fields: [socialLinksId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branches           branch[]
  transactions       transaction[]
  refreshTokenSecret String?
  accessTokenSecret  String?
  moneyInPocket      Float         @default(0)
  fcmToken           String?

  // product            product[]
  // store - restaurant - place for weddings
  role              String   @default("store")
  isApprovedByAdmin Boolean  @default(false)
  isFreezed         Boolean  @default(false)
  isBanned          Boolean  @default(false)
  isDeleted         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  // storeAddress storeAddress[]
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  storeId   String  @unique()
  store     store   @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // twitter    String
  // store     store[]
}

// ===== transaction.prisma =====
model transaction {
  id         String    @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  //deposit , withdraw
  type       String    @default("deposit")
  user       user?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String?
  store      store?    @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId    String?
  amount     Float
  purpose    String?
  currency   currency? @relation(fields: [currencyId], references: [id])
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ===== user-cart.prisma =====
model userCart {
  // id          String        @id @default(uuid())
  userId      String        @unique
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productCart productCart[]
  subtotal    Float         @default(0)
  taxAmount   Float         @default(0)
  deliveryFee Float         @default(0)
  totalAmount Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // @@id([userId, productId])
  // product   product? @relation(fields: [productId], references: [id])
  // productId String?
  @@map("user_cart")
}

// ===== user.prisma =====
model user {
  id                 String        @id @unique @default(uuid())
  name               String
  dateOfBirth        DateTime?
  gender             String?
  moneyInPocket      Float         @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  countryId          String?
  userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  stateId            String?
  userState          state?        @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  phone              String        @unique
  email              String        @unique
  password           String?
  role               String        @default("user")
  isVerified         Boolean       @default(false)
  refreshTokenSecret String?
  accessTokenSecret  String?
  fcmToken           String?
  transaction        transaction[]
  userCart           userCart?
  review             review[]
  order              order[]

  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}
