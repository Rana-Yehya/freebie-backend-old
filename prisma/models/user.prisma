model user {
  id            String        @id @unique @default(uuid())
  name          String
  dateOfBirth   DateTime?
  gender        String?
  moneyInPocket Decimal         @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  // countryId          String?
  // userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  stateId       String?
  state         state?        @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  phone         String        @unique
  email         String        @unique
  // password           String?
  role          String        @default("user")
  isVerified    Boolean       @default(false)
  sessions      session[]     @relation("userSession")
  transaction   transaction[]
  userCart      userCart?
  review        review[]
  order         order[]
  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}
