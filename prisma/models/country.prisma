model country {
  id             String    @id @unique @default(uuid())
  // nameId         String    @unique
  name           locale?   // @relation(fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  currency       currency?
  countryIsoCode String    @unique
  admin          admin[]
  state          state[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
