
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ===== admin.prisma =====
// model adminPrivilege {

// }
model admin {
  id       String    @id @unique @default(uuid())
  name     String
  // dateOfBirth   DateTime?
  // gender        String?
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  // countryId     String?
  // userCountry   country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  phone    String    @unique
  email    String    @unique
  password String
  // privilege          adminPrivilege  
  sessions session[] @relation("adminSession")

  transaction   transaction[]
  moneyInPocket Float         @default(0)

  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
  country   country? @relation(fields: [countryId], references: [id])
  countryId String?
}


// ===== branch.prisma =====
model branch {
  id         String    @id @unique @default(uuid())
  storeId    String
  store      store     @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  location   location? @relation(fields: [locationId], references: [id])
  locationId String?   @unique
  // location     location?

  phone        String?
  isFreezed    Boolean        @default(false)
  workHours    workHour[]
  productStock productStock[]
  // productUser  productCart[]
  // productOrder productOrder[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // branchCity        String
  // branchState       String
  // branchZip         String
  // branchLat         Float
  // branchLng         Float
  // country   country?    @relation(fields: [countryId], references: [id])
  // countryId String?
}

// model branchlocation {
//   id       String  @id @unique @default(uuid())
//   address  String
//   state    state   @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
//   stateId  String
//   branchId String @unique
//   branch   branch @relation(fields: [branchId], references: [id])
//  }

model workHour {
  id        String   @id @unique @default(uuid())
  branchId  String   @unique
  branch    branch   @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  startTime DateTime
  endTime   DateTime
  day       Int
}


// ===== category.prisma =====
model category {
  id                         String    @id @unique @default(uuid())
  nameId                     String   @unique
  name                       locale   @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  imageId                    String
  image                      image     @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product                    product[]
  canBeDeliveredOutsideState Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}
// enum DeliveryPolicy {
//   ANYWHERE
//   WITHIN_STATE
//   WITHIN_COUNTRY
// }

// ===== city.prisma =====
model city {
  id        String   @id @unique @default(uuid())
  nameId    String?  @unique
  name      locale?  @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  state     state    @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // order     order[]
}


// ===== country.prisma =====
model country {
  id             String    @id @unique @default(uuid())
  nameId         String    @unique
  name           locale    @relation(fields: [nameId], references: [id])
  currency       currency?
  countryIsoCode String    @unique
  admin          admin[]
  state          state[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}


// ===== currency.prisma =====
model currency {
  id            String        @id @unique @default(uuid())
  nameId        String        @unique
  name          locale        @relation("currencyName", fields: [nameId], references: [id])
  currencyAbbId String        @unique
  currencyAbb   locale        @relation("currencyAbbLocale", fields: [currencyAbbId], references: [id])
  order         order[]
  transaction   transaction[]
  country       country       @relation(fields: [countryId], references: [id])
  countryId     String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}


// ===== delivery-taxes.prisma =====
model deliveryTaxes {
  id                    String        @id @unique @default(uuid())
  // name               String
  originState           state         @relation("OriginStateFees", fields: [originStateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  originStateId         String
  destinationState      state         @relation("DestinationStateFees", fields: [destinationStateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  destinationStateId    String
  productCart           productCart[]
  baseFee               Float
  additionalFeesAfterKg Float         @default(100)
  feePerKg              Float         @default(0)
  estimatedDays         Int?
  effectiveDate         DateTime      @default(now())
  expiryDate            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  // government            government?   @relation(fields: [governmentId], references: [id])
  // governmentId          String?
  //currency String @default("USD") // Required for multi-currency
  @@unique([originStateId, destinationStateId])
  @@map("delivery_taxes")
}

// minimumFee Decimal @default(0) // New field
// maximumFee Decimal? // New field
// currency String @default("USD") // Required for multi-currency


// ===== image.prisma =====
model image {
  id               String     @id @unique @default(uuid())
  publicId         String
  secureUrl        String
  // userId String? 
  // users  user?   
  category         category[]
  occasion         occasion[]
  product          product?   @relation("imageProduct", fields: [productId], references: [id])
  productId        String?
  mainImageProduct product?   @relation("mainImageProduct")
  storeLogo        store[]    @relation("storeLogo")
  storeBanner      store[]    @relation("storeBanner")
}


// ===== inbox.prisma =====
model inbox {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  email     String
  name      String
  message   String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ===== info.prisma =====
model info {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  slug      String   @unique
  // data      String
  nameId    String   @unique
  name      locale   @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ===== locale.prisma =====
model locale {
  id                         String    @id @unique @default(uuid())
  default                    String?
  en                         String?
  // localeFr      String?
  // localeDe      String?
  // localeEs      String?
  // localeIt      String?
  // localePt      String?
  // localeRu      String?
  // localeZh      String?
  // localeJa      String?
  // localeKo      String?
  ar                         String?
  // localePl      String?
  // localeTr      String?
  // localeCn      String?
  // productId   String? @unique
  nameProduct                product?  @relation("nameProduct") //@relation("locale", fields: [localeProductId], references: [id]) // @relation("ProductTolocale", fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  country                    country?
  state                      state?
  storeName                  store?    @relation("storeName")
  storeBio                   store?    @relation("storeBio")
  currencyAbbLocale          currency? @relation("currencyAbbLocale")
  currencyName               currency? @relation("currencyName")
  city                       city?
  info                       info?
  category                   category?
  occasion                   occasion?
  descriptionProduct         product?  @relation("descriptionProduct") //, references: [id], fields: [descriptionProductId])
  detailedDescriptionProduct product?  @relation("detailedDescriptionProduct") //, references: [id], fields: [detailedDescriptionProductId])
}


// ===== location.prisma =====
model location {
  id       String  @id @unique @default(uuid())
  address  String?
  state    state   @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId  String
  branchId String?
  branch   branch?
  order    order?
}


// ===== occasion.prisma =====
model occasion {
  id        String    @id @unique @default(uuid())
  nameId    String   @unique
  name      locale   @relation(fields: [nameId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  imageId   String
  image     image     @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productOccasion productOccasion[]
  // userId          String
  // user            user              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products  product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


// ===== order.prisma =====
model order {
  id                 String          @id @unique @default(uuid())
  userId             String
  user               user            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  trackingNumber     String
  productOrder       productOrder[]
  subtotal           Float           @default(0)
  taxAmount          Float           @default(0)
  deliveryFee        Float           @default(0)
  totalAmount        Float           @default(0)
  paymentMethod      String //credit_card, paypal, mobile.
  location           location        @relation(fields: [locationId], references: [id])
  locationId         String          @unique
  notes              String
  status             UserOrderStatus @default(UNPAID)
  cancellationReason String?
  refundAmount       Float?
  currencyId         String?
  currency           currency?       @relation(fields: [currencyId], references: [id])
  // estimatedDeliveryDate DateTime       @default(dbgenerated("(NOW() + '7 days'::interval)"))
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

enum UserOrderStatus {
  UNPAID
  PAID
}

