model session {
  id       String  @id @unique @default(uuid())
  fcmToken String?
  user     user?   @relation("userSession", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId   String?
  store    store?  @relation("storeSession", fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId  String?
  admin    admin?  @relation("adminSession", fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  isActive Boolean @default(true)
  adminId  String?
}
