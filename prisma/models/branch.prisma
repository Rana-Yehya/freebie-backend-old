model branch {
  id           String                      @id @unique @default(uuid())
  storeId      String
  store        store                       @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  location     branchLocation?           //        @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  // locationId   String?                     @unique
  // location     location?
  taxOverrides deliveryTaxBranchOverride[]
  phone        String?
  isFreezed    Boolean                     @default(false)
  workHours    workHour[]
  productStock productStock[]
  // discountCodes branchDiscountCode[]
  address    String?
  // productUser  productCart[]
  // productOrder productOrder[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  // branchCity        String
  // branchState       String
  // branchZip         String
  // branchLat         Float
  // branchLng         Float
  // country   country?    @relation(fields: [countryId], references: [id])
  // countryId String?
}

