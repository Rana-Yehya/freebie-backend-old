model productOrder {
  id                 String         @id @unique @default(uuid())
  order              order          @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId            String
  // product            product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId          String
  // branch             branch  @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // branchId           String
  // color              String
  // productStock   productStock? @relation(fields: [productStockId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productStockId String?
  // variant            productVariant @relation(fields: [variantId], references: [id])
  // variantId          String
  productStock       productStock?  @relation(fields: [productStockId], references: [id])
  productStockId     String?
  quantity           Int            @default(1)
  price              Float          @default(0)
  deliveryFee        Float          @default(0)
  subtotal           Float          @default(0)
  status             OrderStatus    @default(PENDING) //pending, confirmed, shipped, delivered, cancelled, refunded
  cancellationReason String?
  userRefundAmount   Float?
  storerRefundAmount Float?
  cancelledBy        OrderCancelBy?

  @@map("product_order")
}

enum OrderCancelBy {
  USER
  STORE
}

enum OrderStatus {
  PENDING
  CANCELLED
  CONFIRMED
  SHIPPED
  DELIVERED
  REFUNDED
}
