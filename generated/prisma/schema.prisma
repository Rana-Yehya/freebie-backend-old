// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model image {
  id     String @id @unique @default(uuid())
  fileId String
  url    String
  // userId String? 
  // users  user?   
}

model user {
  id          String    @id @unique @default(uuid())
  name        String
  dateOfBirth DateTime?
  gender      String?

  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  countryId          String?
  userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull)
  phone              String        @unique
  email              String?       @unique @default("")
  password           String?
  role               String        @default("user")
  isVerified         Boolean       @default(false)
  refreshTokenSecret String?
  accessTokenSecret  String?
  transaction        transaction[]
  products           product[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
  wishList wishList[]
  review   review[]
}

model branch {
  id        String     @id @unique @default(uuid())
  storeId   String
  store     store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  address   String
  state     state      @relation(fields: [stateId], references: [id], onDelete: Cascade)
  stateId   String
  phone     String?
  isFreezed Boolean    @default(false)
  workHours workHour[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  // branchCity        String
  // branchState       String
  // branchZip         String
  // branchLat         Float
  // branchLng         Float
  // country   country?    @relation(fields: [countryId], references: [id])
  // countryId String?
}

model workHour {
  id        String   @id @unique @default(uuid())
  branchId  String   @unique
  branch    branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  day       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model store {
  id                 String        @id @unique @default(uuid())
  name               String
  bio                String
  logo               String
  banner             String
  phone              String        @unique
  email              String        @unique
  password           String
  socialLinksId      String        @unique
  socialLinks        socialLink    @relation(fields: [socialLinksId], references: [id], onDelete: Cascade)
  branches           branch[]
  paymentId          String?
  transactions       transaction[]
  refreshTokenSecret String?
  accessTokenSecret  String?
  product            product[]
  // store - restaurant - place for weddings
  role               String        @default("store")
  isApprovedByAdmin  Boolean       @default(false)
  isFreezed          Boolean       @default(false)
  isBanned           Boolean       @default(false)
  isDeleted          Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  // storeAddress storeAddress[]
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  // twitter    String

  store     store[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model country {
  id             String   @id @unique @default(uuid())
  countryName    String
  currencyCode   String
  countryIsoCode String   @unique
  user           user[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  state          state[]
}

model state {
  id        String   @id @unique @default(uuid())
  name      String
  country   country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  countryId String
  city      city[]
  branches  branch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model city {
  id        String   @id @unique @default(uuid())
  name      String
  state     state    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  stateId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model category {
  id        String    @id @unique @default(uuid())
  name      String
  image     String
  product   product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model occasion {
  id        String    @id @unique @default(uuid())
  name      String
  image     String
  products  product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model product {
  id                       String    @id @unique @default(uuid())
  name                     String
  image                    String[]
  description              String
  detailedDescription      String
  store                    store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId                  String
  user                     user?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId                   String?
  price                    Float     @default(1)
  doesNeedPreparation      Boolean   @default(false)
  isAcceptedByAdmin        Boolean   @default(false)
  isAvailable              Boolean   @default(true)
  isFeatured               Boolean   @default(false)
  isPopular                Boolean   @default(false)
  preparationTimeInMinutes Int       @default(1)
  discountPrecent          Float?    @default(0)
  discountTime             DateTime?
  color                    Int[]
  stock                    Int       @default(1)
  category                 category  @relation(fields: [categoryId], references: [id], onDelete: SetDefault)
  categoryId               String    @default("no_val")
  occasions                occasion  @relation(fields: [occasionsId], references: [id], onDelete: SetDefault)
  occasionsId              String    @default("no_val")
  // branch                   branches  @relation(fields: [branchId], references: [id], onDelete: SetDefault)
  // branchId                 String    @default("no_val")
  reviews                  review[]
  dimensionsWCm            Float     @default(1)
  dimensionsHCm            Float     @default(1)
  dimensionsLCm            Float     @default(1)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model review {
  // id                       String    @id @unique @default(uuid())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, productId])
}

model wishList {
  id        String        @id @default(cuid())
  userId    String
  user      user          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   productUser[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // @@id([userId, productId])
  // product   product? @relation(fields: [productId], references: [id])
  // productId String?
}

model productUser {
  id              String    @id @default(cuid())
  name            String
  image           String
  color           Int[]     @default([])
  price           Float     @default(1)
  discountPrecent Float?    @default(0)
  discountTime    DateTime?
  wishList        wishList  @relation(fields: [wishListId], references: [id])
  wishListId      String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model transaction {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  type      Boolean  @default(false)
  user      user?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  store     store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
