model adCampaign {
  id          String  @id @default(uuid())
  titleId     String  @unique
  title       locale  @relation("titleAd", fields: [titleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  description String?
  image       image   @relation("adImage", fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  imageId     String  @unique

  targetUrl String? // Where the ad clicks go (e.g., store page, product page)

  // // Ad status and timing
  // status       AdStatus  @default(PENDING)
  // startDate    DateTime?
  // endDate      DateTime?

  // scheduledFor DateTime? // When the ad is scheduled to run
  // Ad scheduling (independent of billing period)
  startDate     DateTime // 2024-11-05 (when ad should start showing)
  endDate       DateTime // 2024-11-12 (when ad should stop showing)
  // Tracking
  clicks        Int            @default(0)
  impressions   Int            @default(0)
  adImpressions adImpression[]
  adClick       adClick[]
  targetType    TargetType
  product       product?       @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  productId     String?
  // budget      Float? // Maximum budget for the ad
  // spent       Float  @default(0)

  // Relations - Ad belongs to a specific store (not branch)
  store   store  @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId String

  // // Which branch this ad promotes (optional)
  // branch   branch? @relation(fields: [branchId], references: [id])
  // branchId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ad_campaigns")
}

model adImpression {
  id           String     @id @default(uuid())
  adCampaign   adCampaign @relation(fields: [adCampaignId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adCampaignId String
  userId       String? // If user is logged in
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  @@map("ad_impressions")
}

model adClick {
  id           String     @id @default(uuid())
  adCampaign   adCampaign @relation(fields: [adCampaignId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adCampaignId String
  userId       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  @@map("ad_clicks")
}

enum TargetType {
  STORE_HOME // Store main page
  PRODUCT_PAGE // Specific product
  COLLECTION // Product category/collection  
