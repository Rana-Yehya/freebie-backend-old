  logo                 image              @relation("storeLogo", fields: [logoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bannerId             String             @unique
  banner               image              @relation("storeBanner", fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone                String             @unique
  email                String             @unique
  password             String
  // socialLinksId      String    
  socialLinks          socialLink? //  @relation(fields: [socialLinksId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branches             branch[]
  transactions         transaction[]
  moneyInPocket        Float              @default(0)
  sessions             session[]          @relation("storeSession")
  passwordChangeBefore DateTime?
  // product            product[]
  // store - restaurant - place for weddings
  role                 StoreRole          @default(STORE)
  status               StoreStatus        @default(PENDING)
  subscription         StoreSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId       String? //@unique
  // Store can have multiple ad campaigns
  adCampaigns          AdCampaign[]
  discounts            discount[]
  // isApprovedByAdmin Boolean  @default(false)
  // isFreezed         Boolean  @default(false)
  // isBanned          Boolean  @default(false)
  // isDeleted         Boolean  @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  // storeAddress storeAddress[]
}

enum StoreRole {
  STORE
}

enum StoreStatus {
  PENDING
  APPROVED
  FROZEN
  BANNED
  DELETED
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  storeId   String  @unique()
  store     store   @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // twitter    String
  // store     store[]
}

model SubscriptionPlanChange {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // What changed
  fromPlan   PlanName
  toPlan     PlanName
  changeType ChangeType // UPGRADE, DOWNGRADE, RENEWAL

  // Context
  reason String?

  // Relations
  subscription   StoreSubscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String

  @@map("subscription_plan_changes")
}

enum ChangeType {
  UPGRADE
  DOWNGRADE
  RENEWAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  PAYMENT
  REFUND
}

model transaction {
  id         String          @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  //deposit , withdraw
  type       TransactionType @default(DEPOSIT)
  user       user?           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String?
  store      store?          @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId    String?
  admin      admin?          @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adminId    String?
  amount     Float
  purpose    String?
  currency   currency?       @relation(fields: [currencyId], references: [id])
  currencyId String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model userCart {
  // id          String        @id @default(uuid())
  userId      String        @unique
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productCart productCart[]
  subtotal    Float         @default(0)
  taxAmount   Float         @default(0)
  deliveryFee Float         @default(0)
  totalAmount Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // @@id([userId, productId])
  // product   product? @relation(fields: [productId], references: [id])
  // productId String?
  @@map("user_cart")
}

model user {
  id            String          @id @unique @default(uuid())
  name          String
  dateOfBirth   DateTime?
  gender        String?
  moneyInPocket Float           @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  // countryId          String?
  // userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  userLocations userLocations[]
  stateId       String?
  state         state?          @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  phone         String          @unique
  email         String          @unique
  // password           String?
  role          String          @default("user")
  isVerified    Boolean         @default(false)
  sessions      session[]       @relation("userSession")
  transaction   transaction[]
  userCart      userCart?
  review        review[]
  order         order[]
  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}

model userLocations {
  id      String  @id @unique @default(uuid())
  userId  String
  user    user    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  state   state?  @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId String?
  isMain  Boolean @default(false)
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
