model info {
  id        String   @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  slug      String   @unique
  // data      String
  nameId    String   @unique
  name      locale   @relation(fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
