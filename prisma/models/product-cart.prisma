
model productCart {
  userCart       userCart     @relation(fields: [userCartUserId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  userCartUserId String
  // id         String   @id @unique @default(uuid())
  // cart                   user          @relation(fields: [userCartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // userCartId             String
  // product                product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId              String
  // branch                 branch        @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // branchId               String
  productStock   productStock @relation(fields: [productStockId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productStockId String

  deliveryTaxes          deliveryTaxes @relation(fields: [deliveryTaxesId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deliveryTaxesId        String
  // color                  String
  quantity               Int           @default(1)
  doesHaveEnoughQuantity Boolean       @default(true)
