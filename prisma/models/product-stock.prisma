model productStock {
  id           String         @id @unique @default(uuid())
  // product      product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId    String
  branch       branch         @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branchId     String
  stock        Int?
  // color        String
  productOrder productOrder[]
  productCart  productCart[]
  variant      productVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variantId    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // @@unique([id, branchId])
  // @@unique([productId, branchId, color])
  @@map("product_stock")
}
