model store {
  id   String  @id @unique @default(uuid())
  // nameId String @unique
  name locale? @relation("storeName") //, fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // bioId  String @unique
  bio  locale? @relation("storeBio") //, fields: [bioId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // name               String
  // bio                String
  // logoId               String             @unique
  logo                 image?             @relation("storeLogo") //, fields: [logoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  //bannerId             String             @unique
  banner               image?             @relation("storeBanner")
  // @relation("storeBanner", fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone                String             @unique
  email                String             @unique
  password             String
  // socialLinksId      String    
  socialLinks          socialLink? //  @relation(fields: [socialLinksId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branches             branch[]
  transactions         transaction[]
  moneyInPocket        Float              @default(0)
  sessions             session[]          @relation("storeSession")
  passwordChangeBefore DateTime?
  // product            product[]
  // store - restaurant - place for weddings
  role                 StoreRole          @default(STORE)
  status               StoreStatus        @default(PENDING)
  subscription         storeSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetDefault, onUpdate: SetDefault)
  subscriptionId       String? //@unique
  // Store can have multiple ad campaigns
  adCampaigns          adCampaign[]
  discounts            discount[]
  // isApprovedByAdmin Boolean  @default(false)
  // isFreezed         Boolean  @default(false)
  // isBanned          Boolean  @default(false)
  // isDeleted         Boolean  @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  // storeAddress storeAddress[]
}

enum StoreRole {
  STORE
}

enum StoreStatus {
  PENDING
  APPROVED
  FROZEN
  BANNED
  DELETED
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  storeId   String  @unique()
  store     store   @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // twitter    String
  // store     store[]
}
