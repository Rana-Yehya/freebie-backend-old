model packaging {
  id   String  @id @default(uuid())
  // nameId String @unique
  name locale? // @relation(fields: [nameId], references: [id], onDelete: Cascade) // @relation("namePackage", fields: [nameId], references: [id], onDelete: Cascade)

  // description String?
  price              Float                @default(0)
  dimensionsWCm      Float                @default(1)
  dimensionsHCm      Float                @default(1)
  dimensionsLCm      Float                @default(1)
  weightLimit        Float? // optional weight limit
  packagingVariation packagingVariation[] // @default([])
  // colors        String[]   @default([])
  image              image? //    @relation(fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // imageId       String   @unique

  packageType PackageType

  @@map("packaging")
}

model packagingVariation {
  id          String     @id @default(uuid())
  color       String?
  packaging   packaging  @relation(fields: [packagingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  packagingId String // @unique
  image       image?
  order       order[]
  userCart    userCart[]

  @@unique([packagingId, color])
  //@@unique([id, packagingId])
  @@map("packaging_variation")
}

enum PackageType {
  GIFT_BOX // Rigid boxes (most common)
  GIFT_BAG // Bags with handles
  WRAPPING // Wrap paper, sheets
  TUBE // Cylindrical for posters/maps
  ENVELOPE // Flat for cards/documents
  SPECIALTY // Custom shapes (heart, star, etc.)
  ECO_WRAP // Sustainable materials
}
