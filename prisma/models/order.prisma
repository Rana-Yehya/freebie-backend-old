model order {
  id                   String              @id @unique @default(uuid())
  userId               String
  user                 user                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  trackingNumber       String
  productOrder         productOrder[]
  subtotal             Float               @default(0)
  taxAmount            Float               @default(0)
  deliveryFee          Float               @default(0)
  totalAmount          Float               @default(0)
  paymentMethod        String //credit_card, paypal, mobile.
  location             branchLocation?           @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  locationId           String?
  notes                String
  status               UserOrderStatus     @default(UNPAID)
  packagingVariation   packagingVariation? @relation(fields: [packagingVariationId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  packagingVariationId String?
  cancellationReason   String?
  refundAmount         Float?
  currencyId           String?
  currency             currency?           @relation(fields: [currencyId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  // estimatedDeliveryDate DateTime       @default(dbgenerated("(NOW() + '7 days'::interval)"))
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

enum UserOrderStatus {
  UNPAID
  PAID
}

