model image {
  id               String      @id @unique @default(uuid())
  publicId         String
  secureUrl        String
  // userId String? 
  // users  user?   
  category         category[]
  occasion         occasion[]
  product          product?    @relation("imageProduct", fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId        String?
  ad               adCampaign? @relation("adImage")
  mainImageProduct product?    @relation("mainImageProduct")
  mainImageBundle  bundle?     @relation("mainImageBundle")
  storeLogo        store[]     @relation("storeLogo")
  storeBanner      store[]     @relation("storeBanner")
}
