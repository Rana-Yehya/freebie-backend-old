// ===== product-cart.prisma =====
model productCart {
  userCart        userCart          @relation(fields: [userCartUserId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  userCartUserId  String
  // id                     String         @id @unique @default(uuid())
  // cart                   user          @relation(fields: [userCartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // userCartId             String
  // product                product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId              String
  // branch                 branch        @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // branchId               String
  productStock    productStock      @relation(fields: [productStockId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productStockId  String
  // variant                productVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // variantId              String
  deliveryTaxes   deliveryTaxes?    @relation(fields: [deliveryTaxesId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  deliveryTaxesId String?
  // color                  String
  quantity        Int               @default(1)
  status          ProductCartStatus @default(ACTIVE)
  oldQuantity     Int?              @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  //userCartId
  @@unique([userCartUserId, productStockId])
  @@map("product_cart")
}

enum ProductCartStatus {
  ACTIVE
  NODELIVERYSTATES
  OUTOFSTOCK
}


// ===== product-order.prisma =====
model productOrder {
  id                 String         @id @unique @default(uuid())
  order              order          @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId            String
  // product            product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId          String
  // branch             branch  @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // branchId           String
  // color              String
  // productStock   productStock? @relation(fields: [productStockId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productStockId String?
  // variant            productVariant @relation(fields: [variantId], references: [id])
  // variantId          String
  productStock       productStock?  @relation(fields: [productStockId], references: [id])
  productStockId     String?
  quantity           Int            @default(1)
  price              Float          @default(0)
  deliveryFee        Float          @default(0)
  subtotal           Float          @default(0)
  status             OrderStatus    @default(PENDING) //pending, confirmed, shipped, delivered, cancelled, refunded
  cancellationReason String?
  userRefundAmount   Float?
  storerRefundAmount   Float?
  cancelledBy        OrderCancelBy?

  @@map("product_order")
}

enum OrderCancelBy {
  USER
  STORE
}

enum OrderStatus {
  PENDING
  CANCELLED
  CONFIRMED
  SHIPPED
  DELIVERED
  REFUNDED
}


// ===== product-price.prisma =====
model productPrice {
  productId                    String   @unique
  product                      product     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  actualPrice Float? // @default(1)

  discountPercent          Float?    @default(0)
  discountStartTime        DateTime?
  discountEndTime          DateTime?
  //bulkPricing BulkPricing[]
  @@map("product_price")
}
// minimumOrder: 5
// discountPercent: 10 // 10% off when buying 5+ units

