// ===== product-stock.prisma =====
model productStock {
  id           String         @id @unique @default(uuid())
  // product      product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // productId    String
  branch       branch         @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branchId     String
  stock        Int?
  // color        String
  productOrder productOrder[]
  productCart  productCart[]
  variant      productVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variantId    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // @@unique([id, branchId])
  // @@unique([productId, branchId, color])
  @@map("product_stock")
}


// ===== product-variant.prisma =====
model productVariant {
    id           String         @id @unique @default(uuid())
    product      product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    productId    String
    // Variant attributes (size, color, etc.)
    color        String // e.g., "Color"
    //   option2   String?  // e.g., "Size"
    //   option3   String?  // e.g., "Material"
    // Inventory relationship
    productStock productStock[]
    // productCart  productCart[]
    // productOrder productOrder[]

    @@unique([productId, color])
    @@map("product_variant")
}


// ===== product.prisma =====
// Big sales

//  1 100 000  20%       price = 80 000
//  2 2000     5%        price = 1900
enum ProductTags {
  FEATURED
  POPULAR
  BIGSALE
  NONE
}

model product {
  id                    String  @id @unique @default(uuid())
  nameId                String  @unique
  name                  locale  @relation("nameProduct", fields: [nameId], references: [id])
  // image                      String[]
  image                 image[] @relation("imageProduct")
  mainImage             image   @relation("mainImageProduct", fields: [mainImageId], references: [id])
  mainImageId           String  @unique
  // description                String
  descriptionId         String  @unique
  description           locale  @relation("descriptionProduct", fields: [descriptionId], references: [id])
  detailedDescriptionId String  @unique
  detailedDescription   locale  @relation("detailedDescriptionProduct", fields: [detailedDescriptionId], references: [id])

  // detailedDescription        String
  // store                    store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // storeId                  String
  // user                     user?             @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  // userId                   String?
  price                      Float            @default(1)
  productPrice               productPrice?
  doesNeedPreparation        Boolean          @default(false)
  status                     ProductStatus    @default(PENDING)
  // isFeatured               Boolean   @default(false)
  // isPopular                Boolean   @default(false)
  tags                       ProductTags?
  preparationTimeInMinutes   Int              @default(1)
  canBeDeliveredOutsideState Boolean          @default(true)
  productVariant             productVariant[]
  category                   category?        @relation(fields: [categoryId], references: [id], onDelete: SetDefault, onUpdate: SetDefault)
  categoryId                 String?
  // branch                   branches  @relation(fields: [branchId], references: [id], onDelete: SetDefault, onUpdate: SerDefault)
  // branchId                 String    @default("no_val")
  occasions                  occasion[]
  avgRating                  Float            @default(0)
  reviewsCount               Int              @default(0)
  reviews                    review[]
  dimensionsWCm              Float            @default(1)
  dimensionsHCm              Float            @default(1)
  dimensionsLCm              Float            @default(1)
  weightInKg                 Float            @default(3)
  // productOrder               productOrder[]
  // productUser                productCart[]
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
}

enum ProductStatus {
  PENDING
  APPROVED
  // FROZEN
  // BANNED
  DELETED
}

