// Big sales

//  1 100 000  20%       price = 80 000
//  2 2000     5%        price = 1900
enum ProductTags {
  FEATURED
  POPULAR
  BIGSALE
  NONE
}

model product {
  id                    String  @id @unique @default(uuid())
  nameId                String  @unique
  name                  locale  @relation("nameProduct", fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // image                      String[]
  image                 image[] @relation("imageProduct")
  mainImage             image   @relation("mainImageProduct", fields: [mainImageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  mainImageId           String  @unique
  // description                String
  descriptionId         String  @unique
  description           locale  @relation("descriptionProduct", fields: [descriptionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  detailedDescriptionId String  @unique
  detailedDescription   locale  @relation("detailedDescriptionProduct", fields: [detailedDescriptionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // detailedDescription        String
  // store                    store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // storeId                  String
  // user                     user?             @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  // userId                   String?
  price                      Float            @default(1)
  discount                   discount?
  actualPrice                Float?
  doesNeedPreparation        Boolean          @default(false)
  status                     ProductStatus    @default(PENDING)
  // isFeatured               Boolean   @default(false)
  // isPopular                Boolean   @default(false)
  tags                       ProductTags?
  preparationTimeInMinutes   Int              @default(1)
  canBeDeliveredOutsideState Boolean          @default(true)
  productVariant             productVariant[]
  category                   category?        @relation(fields: [categoryId], references: [id], onDelete: SetDefault, onUpdate: SetDefault)
  categoryId                 String?
  // branch                   branches  @relation(fields: [branchId], references: [id], onDelete: SetDefault, onUpdate: SerDefault)
  // branchId                 String    @default("no_val")
  occasions                  occasion[]
  avgRating                  Float            @default(0)
  reviewsCount               Int              @default(0)
  reviews                    productReview[]
  dimensionsWCm              Float            @default(1)
  dimensionsHCm              Float            @default(1)
  dimensionsLCm              Float            @default(1)
  weightInKg                 Float            @default(3)
  ads                        adCampaign[]
  // productOrder               productOrder[]
  // productUser                productCart[]
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
}

enum ProductStatus {
  PENDING
  APPROVED
  // FROZEN
  // BANNED
  DELETED
}

// lowStockThreshold Int @default(5)
// restockLeadTime Int? // Days needed to restock
// backorderAllowed Boolean @default(false)

// basePrice Decimal @default(0) // More precise than Float
// compareAtPrice Decimal? // For showing "original" price
// costPrice Decimal? // For profit calculations
// currency String @default("USD") // Required for international

// model ProductPrice {
//   product Product @relation(...)
//   // ... existing fields ...
//   discountType DiscountType? @default(PERCENTAGE) // PERCENTAGE or FIXED_AMOUNT
//   minimumOrder Int? // For tiered pricing
//   bulkPricing BulkPricing[] // For quantity breaks
// }

model productReview {
  id        String   @id @unique @default(uuid())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("product_reviews")
}

model bundleReview {
  id        String   @id @unique @default(uuid())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String
  bundle    bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bundleId  String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bundleId])
  @@map("bundle_reviews")
}

model session {
  id       String  @id @unique @default(uuid())
  fcmToken String?
  user     user?   @relation("userSession", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId   String?
  store    store?  @relation("storeSession", fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId  String?
  admin    admin?  @relation("adminSession", fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  isActive Boolean @default(true)
  adminId  String?
}

model state {
  id                       String          @id @unique @default(uuid())
  // name                     String
  nameId                   String          @unique
  name                     locale          @relation(fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade) //onDelete: SetNull, onUpdate: SetNull
  country                  country         @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId                String
  city                     city[]
  userLocations            userLocations[]
  //   @relation(fields: [userLocationsId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  // userLocationsId          String?
  originDeliveryTaxes      deliveryTaxes[] @relation("OriginStateFees")
  destinationDeliveryTaxes deliveryTaxes[] @relation("DestinationStateFees")
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  location                 location[]
}

model storeSubscription {
  id          String             @id @default(uuid())
  // Current active plan
  planLimit   planLimit          @relation(fields: [planLimitId], references: [planName], onDelete: SetDefault, onUpdate: SetDefault)
  planLimitId PlanName           @default(BASIC)
  status      SubscriptionStatus @default(ACTIVE)

  lastChangeSubscriptionDate DateTime?
  periodEnd                  DateTime?
  // Plan limits are now PER STORE (aggregate of all branches)
  maxTotalProducts           Int       @default(0) // Total across all branches
  maxBranches                Int       @default(0) // How many branches allowed
  maxDiscountCodes           Int       @default(0) // Total discount codes across all branches
  notificationsPerWeek       Int       @default(0)
  adsPerWeek                 Int       @default(0)

  // Features
  // allowsBoxes          Boolean @default(false)
  // allowsCollaborations Boolean @default(false)

  // Pricing
  commissionRate Float @default(0.14)

  // Simple ad counter - reset each period
  // adsUsedThisPeriod Int       @default(0) // Tracks 0, 1, 2...
  // adsResetAt        DateTime? // Set to currentPeriodEnd

  // Relations
  // store       store?
  planChanges subscriptionPlanChange[]
  store       store[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@map("store_subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_DOWNGRADE
  CANCELLED
  EXPIRED
}

model store {
  id     String @id @unique @default(uuid())
  nameId String @unique
  name   locale @relation("storeName", fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bioId  String @unique
  bio    locale @relation("storeBio", fields: [bioId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // name               String
  // bio                String
  logoId               String             @unique
  logo                 image              @relation("storeLogo", fields: [logoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bannerId             String             @unique
  banner               image              @relation("storeBanner", fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone                String             @unique
  email                String             @unique
  password             String
  // socialLinksId      String    
  socialLinks          socialLink? //  @relation(fields: [socialLinksId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branches             branch[]
  transactions         transaction[]
  moneyInPocket        Float              @default(0)
  sessions             session[]          @relation("storeSession")
  passwordChangeBefore DateTime?
  // product            product[]
  // store - restaurant - place for weddings
  role                 StoreRole          @default(STORE)
  status               StoreStatus        @default(PENDING)
  subscription         storeSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetDefault, onUpdate: SetDefault)
  subscriptionId       String? //@unique
  // Store can have multiple ad campaigns
  adCampaigns          adCampaign[]
  discounts            discount[]
  // isApprovedByAdmin Boolean  @default(false)
  // isFreezed         Boolean  @default(false)
  // isBanned          Boolean  @default(false)
  // isDeleted         Boolean  @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  // storeAddress storeAddress[]
}

enum StoreRole {
  STORE
}

enum StoreStatus {
  PENDING
  APPROVED
  FROZEN
  BANNED
  DELETED
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  storeId   String  @unique()
  store     store   @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // twitter    String
  // store     store[]
}

model subscriptionPlanChange {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // What changed
  fromPlan                    PlanName
  toPlan                      PlanName
  changeType                  ChangeType // UPGRADE, DOWNGRADE, RENEWAL
  totalProductsUsedThisPeriod Int        @default(0) // Total across all branches
  branchesUsedThisPeriod      Int        @default(0) // How many branches allowed
  discountCodesUsedThisPeriod Int        @default(0) // Total discount codes across all branches
  notificationsUsedThisPeriod Int        @default(0)
  adsUsedThisPeriod           Int        @default(0)

  // Features
  // allowsBoxesUsedThisPeriod          Boolean @default(false)
  // allowsCollaborationsUsedThisPeriod Boolean @default(false)

  // Pricing
  commissionRateUsedThisPeriod Float @default(0.14)

  // Context
  reason String?

  // Relations
  subscription   storeSubscription @relation(fields: [subscriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptionId String

  @@map("subscription_plan_changes")
}

enum ChangeType {
  UPGRADE
  DOWNGRADE
  RENEWAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  PAYMENT
  REFUND
}

model transaction {
  id         String          @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  //deposit , withdraw
  type       TransactionType @default(DEPOSIT)
  user       user?           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String?
  store      store?          @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId    String?
  admin      admin?          @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adminId    String?
  amount     Float
  purpose    String?
  currency   currency?       @relation(fields: [currencyId], references: [id])
  currencyId String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model userCart {
  // id          String        @id @default(uuid())
  userId      String        @unique
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productCart productCart[]
  bundleCart  bundleCart[]

  subtotal    Float    @default(0)
  taxAmount   Float    @default(0)
  deliveryFee Float    @default(0)
  totalAmount Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // @@id([userId, productId])
  // product   product? @relation(fields: [productId], references: [id])
  // productId String?
  @@map("user_cart")
}

model user {
  id                String          @id @unique @default(uuid())
  name              String
  dateOfBirth       DateTime?
  gender            String?
  moneyInPocket     Float           @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  // countryId          String?
  // userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  mainUserLocations userLocations   @relation("MainUserLocation", fields: [userLocationsId], references: [id])
  userLocationsId   String //@default("2aaeb826-8ed5-446a-a194-6370bd9df79e")
  userLocations     userLocations[]
  phone             String          @unique
  email             String          @unique
  password          String? //@default("\$2b\$10\$U9L3L8JLCvzblIc9JGdOY.GpawndsKbSGtdyv0PW1o6UNdMlz6c9C")
  role              String          @default("user")
  isVerified        Boolean         @default(false)
  sessions          session[]       @relation("userSession")
  transaction       transaction[]
  userCart          userCart?
  productReview     productReview[]
  bundleReview      bundleReview[]
  order             order[]
  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}

model userLocations {
  id       String  @id @unique @default(uuid())
  userId   String?
  // mainUser   user    @relation("mainUserLocation", fields: [mainUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // mainUserId String
  user     user?   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  state    state?  @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  stateId  String?
  // isMain  Boolean @default(false)
  mainUser user[]  @relation("MainUserLocation")

  @@unique([userId, stateId])
  @@map("user_locations")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
