// ===== review.prisma =====
model review {
  id        String   @id @unique @default(uuid())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}


// ===== session.prisma =====
model session {
  id       String  @id @unique @default(uuid())
  fcmToken String?
  user     user?   @relation("userSession", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId   String?
  store    store?  @relation("storeSession", fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId  String?
  admin    admin?  @relation("adminSession", fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  isActive Boolean @default(true)
  adminId  String?
}


// ===== state.prisma =====
model state {
  id                       String          @id @unique @default(uuid())
  // name                     String
  nameId                   String          @unique
  name                     locale          @relation(fields: [nameId], references: [id]) //onDelete: SetNull, onUpdate: SetNull
  country                  country         @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  countryId                String
  city                     city[]
  userLocations            userLocations[]
  //   @relation(fields: [userLocationsId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  // userLocationsId          String?
  originDeliveryTaxes      deliveryTaxes[] @relation("OriginStateFees")
  destinationDeliveryTaxes deliveryTaxes[] @relation("DestinationStateFees")
  user                     user[]
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  location                 location[]
}


// ===== store.prisma =====
model store {
  id     String @id @unique @default(uuid())
  nameId String @unique
  name   locale @relation("storeName", fields: [nameId], references: [id])
  bioId  String @unique
  bio    locale @relation("storeBio", fields: [bioId], references: [id])

  // name               String
  // bio                String
  logoId               String        @unique
  logo                 image         @relation("storeLogo", fields: [logoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bannerId             String        @unique
  banner               image         @relation("storeBanner", fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone                String        @unique
  email                String        @unique
  password             String
  // socialLinksId      String    
  socialLinks          socialLink? //  @relation(fields: [socialLinksId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branches             branch[]
  transactions         transaction[]
  moneyInPocket        Decimal       @default(0)
  sessions             session[]     @relation("storeSession")
  passwordChangeBefore DateTime?
  // product            product[]
  // store - restaurant - place for weddings
  role                 String        @default("store")
  status               StoreStatus   @default(PENDING)

  // isApprovedByAdmin Boolean  @default(false)
  // isFreezed         Boolean  @default(false)
  // isBanned          Boolean  @default(false)
  // isDeleted         Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // storeAddress storeAddress[]
}

enum StoreStatus {
  PENDING
  APPROVED
  FROZEN
  BANNED
  DELETED
}

model socialLink {
  id        String  @id @unique @default(uuid())
  tiktok    String?
  youtube   String?
  facebook  String?
  x         String?
  instagram String?
  storeId   String  @unique()
  store     store   @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // twitter    String
  // store     store[]
}


// ===== transaction.prisma =====
enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  PAYMENT
  REFUND
}

model transaction {
  id         String          @id @unique @default(uuid())
  // buy something or take money from wallet -> false = buy, true = take
  //deposit , withdraw
  type       TransactionType @default(DEPOSIT)
  user       user?           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String?
  store      store?          @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId    String?
  admin      admin?          @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adminId    String?
  amount     Float
  purpose    String?
  currency   currency?       @relation(fields: [currencyId], references: [id])
  currencyId String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}


// ===== user-cart.prisma =====
model userCart {
  // id          String        @id @default(uuid())
  userId      String        @unique
  user        user          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productCart productCart[]
  subtotal    Float         @default(0)
  taxAmount   Float         @default(0)
  deliveryFee Float         @default(0)
  totalAmount Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // @@id([userId, productId])
  // product   product? @relation(fields: [productId], references: [id])
  // productId String?
  @@map("user_cart")
}


// ===== user.prisma =====
model user {
  id            String          @id @unique @default(uuid())
  name          String
  dateOfBirth   DateTime?
  gender        String?
  moneyInPocket Decimal         @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  // countryId          String?
  // userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  userLocations userLocations[]
  stateId       String?
  state         state?          @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  phone         String          @unique
  email         String          @unique
  // password           String?
  role          String          @default("user")
  isVerified    Boolean         @default(false)
  sessions      session[]       @relation("userSession")
  transaction   transaction[]
  userCart      userCart?
  review        review[]
  order         order[]
  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}

model userLocations {
  id      String  @id @unique @default(uuid())
  userId  String
  user    user    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  state   state?  @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateId String?
  isMain  Boolean @default(false)
}

