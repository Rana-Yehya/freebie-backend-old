model user {
  id                String          @id @unique @default(uuid())
  name              String
  dateOfBirth       DateTime?
  gender            String?
  moneyInPocket     Float           @default(0)
  // is the country is deleted, the user country will be set to null
  // what is the action after this?
  // countryId          String?
  // userCountry        country?      @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  mainUserLocations userLocations   @relation("MainUserLocation", fields: [userLocationsId], references: [id])
  userLocationsId   String  //@default("2aaeb826-8ed5-446a-a194-6370bd9df79e")
  userLocations     userLocations[] 
  phone             String          @unique
  email             String          @unique
  // password           String?
  role              String          @default("user")
  isVerified        Boolean         @default(false)
  sessions          session[]       @relation("userSession")
  transaction       transaction[]
  userCart          userCart?
  productReview     productReview[]
  bundleReview      bundleReview[]
  order             order[]
  // categoriesInterest category[]
  // occasionsInterest  occasion[]

  // products           product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // imageId     String?  
  // avatar      image?    @relation(fields: [imageId], references: [id])
}

model userLocations {
  id       String  @id @unique @default(uuid())
  userId   String
  // mainUser   user    @relation("mainUserLocation", fields: [mainUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // mainUserId String
  user     user    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  state    state?  @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  stateId  String?
  // isMain  Boolean @default(false)
  mainUser user[]  @relation("MainUserLocation")

  @@unique([userId, stateId])
  @@map("user_locations")
}
