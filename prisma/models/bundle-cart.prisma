model bundleCart {
  userCart        userCart          @relation(fields: [userCartUserId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  userCartUserId  String
  bundle          bundle            @relation(fields: [bundleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bundleId        String
  // variant                productVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // variantId              String
  deliveryTaxes   deliveryTaxes?    @relation(fields: [deliveryTaxesId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  deliveryTaxesId String?
  // color                  String
  quantity        Int               @default(1)
  status          ProductCartStatus @default(ACTIVE)
  oldQuantity     Int?              @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  //userCartId
  @@unique([userCartUserId, bundleId])
  @@map("bundle_cart")
}

