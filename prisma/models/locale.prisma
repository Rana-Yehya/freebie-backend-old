model locale {
  id                         String      @id @unique @default(uuid())
  default                    String?
  en                         String?
  // localeFr      String?
  // localeDe      String?
  // localeEs      String?
  // localeIt      String?
  // localePt      String?
  // localeRu      String?
  // localeZh      String?
  // localeJa      String?
  // localeKo      String?
  ar                         String?
  // localePl      String?
  // localeTr      String?
  // localeCn      String?
  // productId   String? @unique
  ad                         adCampaign? @relation("titleAd")
  nameBundle                 bundle?     @relation("nameBundle") //@relation("locale", fields: [localeProductId], references: [id]) // @relation("ProductTolocale", fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  descriptionBundle          bundle?     @relation("descriptionBundle") //@relation("locale", fields: [localeProductId], references: [id]) // @relation("ProductTolocale", fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  nameProduct                product?    @relation("nameProduct") //@relation("locale", fields: [localeProductId], references: [id]) // @relation("ProductTolocale", fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  country                    country?
  state                      state?
  storeName                  store?      @relation("storeName")
  storeBio                   store?      @relation("storeBio")
  currencyAbbLocale          currency?   @relation("currencyAbbLocale")
  currencyName               currency?   @relation("currencyName")
  city                       city?
  info                       info?
  category                   category?
  occasion                   occasion?
  descriptionProduct         product?    @relation("descriptionProduct") //, references: [id], fields: [descriptionProductId])
  detailedDescriptionProduct product?    @relation("detailedDescriptionProduct") //, references: [id], fields: [detailedDescriptionProductId])
}
