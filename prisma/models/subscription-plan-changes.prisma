model SubscriptionPlanChange {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())

    // What changed
    fromPlan   PlanName
    toPlan     PlanName
    changeType ChangeType // UPGRADE, DOWNGRADE, RENEWAL

    // Context
    reason String?

    // Relations
    subscription   StoreSubscription @relation(fields: [subscriptionId], references: [id])
    subscriptionId String

    @@map("subscription_plan_changes")
}


enum ChangeType {
    UPGRADE
    DOWNGRADE
    RENEWAL
}
